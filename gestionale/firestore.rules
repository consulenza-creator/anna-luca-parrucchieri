rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Prenotazioni: chiunque può crearne una nuova dal sito pubblico
    // (prenota.html), ma solo Anna e Luca autenticati possono leggerle,
    // modificarle (cambio stato) o cancellarle dal gestionale.
    match /prenotazioni/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Prodotti: solo il gestionale (autenticato) legge e scrive.
    match /prodotti/{id} {
      allow read, write: if request.auth != null;
    }

    // Ferie: il sito pubblico deve poterle leggere per calcolare gli
    // slot disponibili, ma solo Anna e Luca possono modificarle.
    match /ferie/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Disponibilità: copia "senza dati personali" di ogni prenotazione
    // (solo data/ora/operatore/durata, niente nome/telefono/email/note),
    // usata da prenota.html per calcolare gli slot liberi senza esporre
    // i dati dei clienti a chi non è autenticato. Creata insieme alla
    // prenotazione vera; cancellata da Anna e Luca quando annullano.
    match /disponibilita/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
  }
}
